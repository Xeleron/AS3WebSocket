        }
        public function get isDisposed():Boolean
        {
            return _disposed;
        }

        /**
         * Dispose of the network manager.
         */
        public function dispose():void
        {
            if (_disposed)
                return;

            disconnect();

            if (_ws)
            {
                _ws.removeEventListener(WebSocketEvent.OPEN, onWSOpen);
                _ws.removeEventListener(WebSocketEvent.CLOSED, onWSClosed);
                _ws.removeEventListener(WebSocketEvent.MESSAGE, onWSMessage);
                _ws.removeEventListener(WebSocketErrorEvent.CONNECTION_FAIL, onWSError);
                _ws.removeEventListener(WebSocketErrorEvent.ABNORMAL_CLOSE, onWSAbnormalClose);
                _ws.removeEventListener(IOErrorEvent.IO_ERROR, onWSIOError);
                _ws.removeEventListener(SecurityErrorEvent.SECURITY_ERROR, onWSSecurityError);
                _ws = null;
            }

            // Dispose signals
            onConnected.dispose();
            onDisconnected.dispose();
            onError.dispose();
            onMessage.dispose();
            onExtensionResponse.dispose();

            // Dispose event manager
            if (_eventManager)
            {
                _eventManager.dispose();
                _eventManager = null;
            }

            clearHandlers();

            _game = null;

            _disposed = true;
        }
    }
