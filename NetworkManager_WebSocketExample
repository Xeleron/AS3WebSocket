        private function handleError(message:String):void
        {
            if (_lastFailureMessage == message)
            {
                debug("handleError duplicate ignored: " + message);
                return;
            }

            _lastFailureMessage = message;
            debug("handleError: " + message);
            _connected = false;
            _connecting = false;
            stopPollTimer();

            onError.dispatch(message);

            if (useSecureTransport)
            {
                debug("Not reconnecting on WSS failure; this is a deterministic TLS/WebSocket handshake failure");
                if (_game)
                    _game.handleConnectionLost(message);
                return;
            }

            // Try to reconnect
            if (_reconnectAttempts < _maxReconnectAttempts)
            {
                _reconnectAttempts++;
                debug("Reconnect attempt " + _reconnectAttempts);

                _game.timerManager.delayCall(_reconnectDelay, function():void
                    {
                        connect();
                    });
            }
            else
            {
                debug("Max retries reached, giving up");
                if (_game)
                    _game.handleConnectionLost(message);
            }
        }

        /**
         * Disconnect from the server.
         */
        public function disconnect():void
        {
            if (_disposed)
                return;

            _connected = false;
            _connecting = false;

            if (_ws)
            {
                try { _ws.close(false); } catch (e:Error) {}
            }

            onDisconnected.dispatch("Disconnected by client");
        }

        // ==================== Send Helpers ====================

        /**
         * Send a raw string over the WebSocket as a binary frame (SFS null-byte terminated).
         */
        private function sendRaw(msg:String):void
        {
            if (!_ws || !_ws.connected)
                return;

            var payload:flash.utils.ByteArray = new flash.utils.ByteArray();
            payload.writeUTFBytes(msg);
            payload.writeByte(0);
            _ws.sendBytes(payload);

            debug("[TX] " + (msg.length > 120 ? msg.substr(0, 120) + "..." : msg));
        }

        /**
         * Send login credentials to the server.
         * Uses the auth token from loginInfo, not password.
         */
        public function sendLogin():void
        {
            debug("sendLogin() called");

            if (_disposed || !_connected || !_ws)
            {
                debug("sendLogin: disposed=" + _disposed + " connected=" + _connected);
                return;
            }

            var loginInfo:Object = _game.loginInfo;
            if (!loginInfo || !loginInfo.strUsername)
            {
                debug("sendLogin: No login info available");
                return;
            }

            var username:String = loginInfo.strUsername;
            var token:String = loginInfo.strToken || loginInfo.sToken || "";

            // Build login string: clientToken~username~clientVersion
            var loginStr:String = Game.CLIENT_TOKEN + "~" + username + "~" + Game.CLIENT_VERSION;

            debug("Login user: " + username);
            debug("Login str: " + loginStr);
            debug("Token len: " + token.length);

            // SFS XML login message
            var msg:String = "<msg t='sys'><body action='login' r='0'><login z=\'" + LOGIN_ZONE + "\'><nick><![CDATA[" + loginStr + "]]></nick><pword><![CDATA[" + token + "]]></pword></login></body></msg>";
            sendRaw(msg);

            debug("login sent");
        }

        /**
         * Send an extension message to the server.
         */
        public function sendExtensionMessage(cmd:String, params:Object = null, type:String = "str", room:int = -1):void
        {
            if (_disposed || !_connected || !_ws)
                return;

            if (room == -1)
                room = activeRoomId;

            if (type == "str")
            {
                var strMsg:String = "%xt%zm%" + cmd + "%" + room + "%";
                if (params is Array)
                {
                    for (var i:int = 0; i < (params as Array).length; i++)
                    {
                        strMsg += params[i] + "%";
                    }
                }
                else if (params)
                {
                    for (var key:String in params)
                    {
                        strMsg += params[key] + "%";
                    }
                }
                sendRaw(strMsg);
            }
            else if (type == "json")
            {
                var obj:Object = {
                    t: "xt",
                    b: {
                        x: "zm",
                        c: cmd,
                        r: room,
                        p: params
                    }
                };
                sendRaw(JSONHelper.encode(obj));
            }
        }

        /**
         * Send a message (legacy method for compatibility).
         */
        public function send(data:*):void
        {
            if (_disposed || !_connected || !_ws)
                return;

            if (data is Object && data.cmd)
            {
                sendExtensionMessage(data.cmd, data);
                return;
            }

            trace("[NetworkManager] Cannot send raw data: " + data);
        }

        /**
         * Send move command to server.
         */
        public function sendMove(tx:int, ty:int, sp:int = 8):void
        {
            if (_disposed || !_connected || !_ws)
                return;

            var data:Array = ["mv", tx, ty, sp];
            sendExtensionMessage("mv", data, "str", 1);

            debug("Sent move: tx=" + tx + " ty=" + ty);
        }

        /**
         * Register a handler for a specific message type.
         */
        public function registerHandler(type:String, handler:Function):void
        {
            if (!_messageHandlers[type])
                _messageHandlers[type] = [];

            _messageHandlers[type].push(handler);
        }

        /**
         * Unregister a handler.
         */
        public function unregisterHandler(type:String, handler:Function):void
        {
            if (!_messageHandlers[type])
                return;

            var handlers:Array = _messageHandlers[type];
            var index:int = handlers.indexOf(handler);
            if (index != -1)
                handlers.splice(index, 1);
        }

        /**
         * Clear all handlers.
         */
        public function clearHandlers():void
        {
            _messageHandlers = {};
        }

        /**
         * Compatibility shim: returns `this` so that World.as code like
         * _game.networkManager.sfc.myUserId still works. The properties
         * myUserId, myUserName, activeRoomId live directly on NetworkManager.
         */
        public function get sfc():NetworkManager
        {
