        /**
         * Handle combat tick - HP/MP/state updates.
         */
        private function handleCombatTick(data:Object):void
        {
            // Update monsters
            if (data.m)
            {
                for (var monId:String in data.m)
                {
                    if (_game && _game.world)
                    {
                        _game.world.handleMtls({id: int(monId), o: data.m[monId]});
                    }
                }
            }

            // Update players
            if (data.p)
            {
                for (var username:String in data.p)
                {
                    if (_game && _game.world)
                    {
                        _game.world.handleUotls({unm: username, o: data.p[username]});
                    }
                }
            }

            // Handle auras
            if (data.a)
            {
                for each (var auraEvent:Object in data.a)
                {
                    if (auraEvent.cmd == "aura+")
                        handleAuraAdd(auraEvent);
                    else if (auraEvent.cmd == "aura-")
                        handleAuraRemove(auraEvent);
                }
            }
        }

        /**
         * Handle combat batch - similar to ct but for batch updates.
         */
        private function handleCombatBatch(data:Object):void
        {
            // Same handling as combat tick
            handleCombatTick(data);
        }

        /**
         * Handle addGoldExp - gold and experience rewards.
         */
        private function handleAddGoldExp(data:Object):void
        {
            if (!_game || !_game.world || !_game.world.myAvatar)
                return;

            var myAvatar:* = _game.world.myAvatar;

            if (data.intExp != null && data.intExp > 0)
            {
                var deltaXP:int = int(data.intExp);
                if (myAvatar.objData)
                {
                    myAvatar.objData.intExp = int(myAvatar.objData.intExp || 0) + deltaXP;
                }
                debug("XP gained: " + deltaXP);
            }

            if (data.intGold != null && data.intGold > 0)
            {
                var deltaGold:int = int(data.intGold);
                if (myAvatar.objData)
                {
                    myAvatar.objData.intGold = int(myAvatar.objData.intGold || 0) + deltaGold;
                }
                debug("Gold gained: " + deltaGold);
            }

            // Class points
            if (data.iCP != null)
            {
                var deltaCP:int = int(data.iCP);
                if (myAvatar.objData)
                {
                    myAvatar.objData.iCP = int(myAvatar.objData.iCP || 0) + deltaCP;
                }
                debug("Class Points gained: " + deltaCP);
            }

            // Faction rep
            if (data.FactionID != null && data.iRep != null)
            {
                debug("Faction " + data.FactionID + " rep: " + data.iRep);
            }
        }

